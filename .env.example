# ═══════════════════════════════════════════
# KIMY — Variables de Entorno
# ═══════════════════════════════════════════

# Base de datos PostgreSQL (pgvector)
POSTGRES_USER=kimy
POSTGRES_PASSWORD=kimy_secret_2026
POSTGRES_DB=kimy_thesis
DATABASE_URL=postgresql://kimy:kimy_secret_2026@localhost:5434/kimy_thesis

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=thesis-documents
MINIO_USE_SSL=false
# ⚠ En producción, cambiar MINIO_ACCESS_KEY y MINIO_SECRET_KEY

# IA — OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=
AI_MODEL=gpt-4o
AI_EMBEDDING_MODEL=text-embedding-3-large

# IA — Ollama (alternativa local gratuita)
# OLLAMA_BASE_URL=http://localhost:11434
# AI_PROVIDER=ollama

# Auth
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
JWT_EXPIRES_IN=7d
NEXTAUTH_SECRET=CHANGE_ME_IN_PRODUCTION
NEXTAUTH_URL=http://localhost:3000

# Configuración académica
MAX_GRADE=20
LOW_COMPLIANCE_ALERT=60
INSTITUTION_NAME=Universidad Nacional

# Fine-tuning
FT_MIN_PAIRS=500

# ORCID OAuth (opcional)
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=

# Copyleaks (opcional)
COPYLEAKS_ACCESS_TOKEN=

# Encriptación
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# App Móvil
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_PROJECT_ID=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
API_PORT=3001
WEB_PORT=3000
APP_URL=http://localhost:3000
