// ═══════════════════════════════════════════════════════════════
// KIMY — Schema Prisma Completo
// Sistema de Revisión Inteligente de Tesis
// ═══════════════════════════════════════════════════════════════

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─── Enums ───────────────────────────────────────────────────

enum Role {
  STUDENT
  ADVISOR
  COORDINATOR
  ADMIN
}

enum AdvanceStatus {
  PENDING
  AI_PROCESSING
  AI_COMPLETE
  HUMAN_REVIEW
  OBSERVED
  APPROVED
  REJECTED
}

enum FindingSeverity {
  CRITICAL
  MAJOR
  MINOR
  SUGGESTION
}

enum FindingAction {
  ACCEPTED
  MODIFIED
  REJECTED
}

enum PlagiarismMethod {
  EMBEDDINGS_COSINE
  COPYLEAKS_API
}

enum ReferenceStatus {
  VERIFIED
  PARTIAL
  NOT_FOUND
  HALLUCINATED
}

enum FineTuningStatus {
  COLLECTING
  READY
  TRAINING
  COMPLETED
  FAILED
}

enum PairOutcome {
  ACCEPTED
  ACCEPTED_WITH_EDIT
  DISCARDED
  SEVERITY_CHANGED
}

enum TranslationStatus {
  PENDING
  DETECTING_LANG
  TRANSLATING
  COMPLETED
  FAILED
}

// ─── Core Models ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  role          Role      @default(STUDENT)
  avatarUrl     String?
  isActive      Boolean   @default(true)

  // Relaciones de programa
  programId     String?
  program       Program?  @relation(fields: [programId], references: [id])

  // Relación asesor-estudiante
  advisorId     String?
  advisor       User?     @relation("AdvisorStudents", fields: [advisorId], references: [id])
  advisees      User[]    @relation("AdvisorStudents")

  // Relaciones
  advances      Advance[]
  reviews       Review[]
  orcidProfile  OrcidProfile?
  pushTokens    UserPushToken[]
  notifications Notification[]
  auditLogs         AuditLog[]
  loginRecords      LoginRecord[]
  thesisGenerations   ThesisGeneration[]
  chatConversations    ChatConversation[]
  documentTranslations DocumentTranslation[]

  // Preferencias de Perfil y Notificaciones
  signature      String?
  notifyComplete Boolean   @default(true)
  notifyPush     Boolean   @default(false)
  notifyWeekly   Boolean   @default(true)
  preferences    Json?

  // 2FA
  twoFactorSecret      String?
  twoFactorBackupCodes String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@index([role])
  @@index([programId])
}

model LoginRecord {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String
  device    String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─── Settings ────────────────────────────────────────────────

model SystemSettings {
  id               String   @id @default("default")
  institutionName  String   @default("Universidad Nacional de Trujillo")
  maxGrade         Int      @default(20)
  aiModel          String   @default("gpt-4o")
  aiProvider       String   @default("openai")
  approvalThreshold Float   @default(60)
  rigorLevel       String   @default("Alto")
  updatedAt        DateTime @updatedAt
}

model Program {
  id          String           @id @default(cuid())
  name        String           @unique
  code        String           @unique
  description String?
  isActive    Boolean          @default(true)

  users       User[]
  templates   ThesisTemplate[]
  advances    Advance[]
  periods     DeliveryPeriod[]

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model DeliveryPeriod {
  id          String    @id @default(cuid())
  programId   String
  program     Program   @relation(fields: [programId], references: [id])
  name        String
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean   @default(true)

  createdAt   DateTime  @default(now())

  @@index([programId, isActive])
}

// ─── Document Template Models ────────────────────────────────

model ThesisTemplate {
  id               String          @id @default(cuid())
  programId        String
  program          Program         @relation(fields: [programId], references: [id])
  name             String
  version          String
  fileKey          String
  fileType         String
  extractedSchema  Json?
  formatting       Json?
  rubric           Json?
  citationStyle    String          @default("APA")
  isActive         Boolean         @default(true)

  chunks           TemplateChunk[]
  advances         Advance[]

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([programId, isActive])
}

model TemplateChunk {
  id          String   @id @default(cuid())
  templateId  String
  template    ThesisTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sectionName String
  content     String
  embedding   Unsupported("vector(3072)")?
  chunkIndex  Int

  createdAt   DateTime @default(now())

  @@index([templateId])
}

// ─── Advance Models ──────────────────────────────────────────

model Advance {
  id            String        @id @default(cuid())
  studentId     String
  student       User          @relation(fields: [studentId], references: [id])
  programId     String
  program       Program       @relation(fields: [programId], references: [id])
  templateId    String
  template      ThesisTemplate @relation(fields: [templateId], references: [id])

  title         String
  advanceType   String
  version       Int           @default(1)
  fileKey       String
  fileType      String
  fileSizeBytes Int
  pageCount     Int?
  extractedText String?

  status        AdvanceStatus @default(PENDING)

  // Relaciones
  aiAnalysis        AIAnalysis?
  review            Review?
  chunks            AdvanceChunk[]
  plagiarismReports PlagiarismReport[]
  plagiarismTargets PlagiarismAlert[]  @relation("PlagiarismTarget")
  referenceAnalysis ReferenceAnalysis?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([studentId])
  @@index([programId])
  @@index([status])
  @@index([studentId, advanceType])
}

model AdvanceChunk {
  id          String   @id @default(cuid())
  advanceId   String
  advance     Advance  @relation(fields: [advanceId], references: [id], onDelete: Cascade)
  sectionName String
  content     String
  embedding   Unsupported("vector(3072)")?
  chunkIndex  Int

  createdAt   DateTime @default(now())

  @@index([advanceId])
}

// ─── AI Analysis Models ──────────────────────────────────────

model AIAnalysis {
  id                String      @id @default(cuid())
  advanceId         String      @unique
  advance           Advance     @relation(fields: [advanceId], references: [id], onDelete: Cascade)

  structureScore    Float
  contentScore      Float
  formScore         Float
  originalityScore  Float
  overallScore      Float
  gradeConverted    Float

  executiveSummary  String
  structureAnalysis Json?
  detailedFeedback  Json?
  processingMs      Int
  modelUsed         String

  findings          AIFinding[]

  createdAt         DateTime    @default(now())

  @@index([advanceId])
}

model AIFinding {
  id                 String          @id @default(cuid())
  analysisId         String
  analysis           AIAnalysis      @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  sectionRef         String
  pageRef            Int?
  severity           FindingSeverity
  description        String
  correctionSteps    String
  exampleImprovement String
  recommendation     String

  // Feedback humano
  humanAction        FindingAction?
  humanComment       String?
  adjustedSeverity   FindingSeverity?
  adjustedDescription String?
  reviewedAt         DateTime?

  // Fine-tuning pair
  fineTuningPair     FineTuningPair?

  createdAt          DateTime        @default(now())

  @@index([analysisId])
  @@index([severity])
}

// ─── Review Models ───────────────────────────────────────────

model Review {
  id             String        @id @default(cuid())
  advanceId      String        @unique
  advance        Advance       @relation(fields: [advanceId], references: [id], onDelete: Cascade)
  reviewerId     String
  reviewer       User          @relation(fields: [reviewerId], references: [id])

  finalGrade     Float?
  aiGrade        Float?
  humanComment   String?
  rubricAnswers  Json?
  status         AdvanceStatus
  annotations    Json?

  reviewedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([reviewerId])
}

// ─── Plagiarism Models ───────────────────────────────────────

model PlagiarismReport {
  id           String            @id @default(cuid())
  advanceId    String
  advance      Advance           @relation(fields: [advanceId], references: [id], onDelete: Cascade)
  method       PlagiarismMethod
  overallScore Float             @default(0)
  status       String            @default("pending")
  externalId   String?

  alerts       PlagiarismAlert[]

  createdAt    DateTime          @default(now())

  @@index([advanceId])
}

model PlagiarismAlert {
  id              String            @id @default(cuid())
  reportId        String
  report          PlagiarismReport  @relation(fields: [reportId], references: [id], onDelete: Cascade)

  targetAdvanceId String?
  targetAdvance   Advance?          @relation("PlagiarismTarget", fields: [targetAdvanceId], references: [id])

  sectionName     String
  similarity      Float
  sourceSnippet   String?
  targetSnippet   String?
  severity        String

  createdAt       DateTime          @default(now())

  @@index([reportId])
  @@index([similarity])
}

// ─── Reference Validation Models ─────────────────────────────

model ReferenceAnalysis {
  id            String      @id @default(cuid())
  advanceId     String      @unique
  advance       Advance     @relation(fields: [advanceId], references: [id], onDelete: Cascade)
  totalRefs     Int
  verifiedCount Int         @default(0)
  errorCount    Int         @default(0)

  references    Reference[]

  createdAt     DateTime    @default(now())
}

model Reference {
  id           String          @id @default(cuid())
  analysisId   String
  analysis     ReferenceAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  rawText      String
  authors      String?
  year         Int?
  title        String?
  journal      String?
  volume       String?
  issue        String?
  doi          String?
  url          String?
  status       ReferenceStatus
  errorType    String?
  suggestion   String?
  crossrefData Json?

  createdAt    DateTime        @default(now())

  @@index([analysisId])
  @@index([status])
}

// ─── Fine-tuning Models ──────────────────────────────────────

model FineTuningDataset {
  id          String            @id @default(cuid())
  name        String
  description String?
  status      FineTuningStatus  @default(COLLECTING)
  pairCount   Int               @default(0)
  modelId     String?
  jobId       String?
  accuracy    Float?
  f1Score     Float?

  pairs       FineTuningPair[]

  createdAt   DateTime          @default(now())
  completedAt DateTime?
}

model FineTuningPair {
  id              String             @id @default(cuid())
  datasetId       String?
  dataset         FineTuningDataset? @relation(fields: [datasetId], references: [id])
  findingId       String             @unique
  finding         AIFinding          @relation(fields: [findingId], references: [id])
  originalOutput  Json
  humanCorrection Json
  outcomeType     PairOutcome
  reviewerId      String
  advanceType     String
  programId       String

  createdAt       DateTime           @default(now())

  @@index([datasetId])
  @@index([outcomeType])
}

// ─── ORCID Models ────────────────────────────────────────────

model OrcidProfile {
  id            String             @id @default(cuid())
  userId        String             @unique
  user          User               @relation(fields: [userId], references: [id])
  orcidId       String             @unique
  accessToken   String
  refreshToken  String
  tokenExpiry   DateTime
  displayName   String?
  biography     String?
  keywords      String[]

  publications  OrcidPublication[]

  lastSyncedAt  DateTime?
  createdAt     DateTime           @default(now())
}

model OrcidPublication {
  id        String       @id @default(cuid())
  profileId String
  profile   OrcidProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  putCode   String
  title     String
  journal   String?
  year      Int?
  doi       String?
  workType  String?
  url       String?
  keywords  String[]

  createdAt DateTime     @default(now())

  @@index([profileId])
}

// ─── Chat / AI Assistant Models ─────────────────────────────

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

model ChatConversation {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("Nueva conversación")
  modelUsed String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId])
  @@index([updatedAt])
}

model ChatMessage {
  id             String          @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  toolCalls      Json?
  toolResults    Json?
  audioUrl       String?
  createdAt      DateTime        @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ─── Notification & Audit Models ─────────────────────────────

model UserPushToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  platform  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  type      String
  data      Json?
  read      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entity, entityId])
}

model ThesisGeneration {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  templateId   String
  templateName String   @default("")
  topic        String
  userPrompt   String?
  sectionNames String[]
  aiProvider   String   @default("groq")
  content      String
  status       String   @default("COMPLETED")

  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

// ─── Document Translation Models ────────────────────────────

model DocumentTranslation {
  id                 String            @id @default(uuid())
  userId             String
  user               User              @relation(fields: [userId], references: [id])
  originalFileKey    String
  originalFileName   String
  fileType           String
  sourceLang         String
  targetLang         String
  detectedLang       String?
  correctedLang      String?
  status             TranslationStatus @default(PENDING)
  content            String?
  translatedContent  String?
  chunkCount         Int?
  completedChunks    Int               @default(0)
  processingMs       Int?
  modelUsed          String?
  errorMessage       String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([userId])
  @@index([status])
}
